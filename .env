# ---------- Database (docker-compose.yml expects these) ----------
POSTGRESDB_USER=postgres
POSTGRESDB_ROOT_PASSWORD=change_me
POSTGRESDB_DATABASE=partner-api
POSTGRESDB_LOCAL_PORT=5439
POSTGRESDB_DOCKER_PORT=5432

# Optional (used by settings.py if present)
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- Django ----------
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.spc.int,http://localhost*
DJANGO_SECRET_KEY=change_me

# CORS
CORS_ALLOW_ALL_ORIGINS=true
